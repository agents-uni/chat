{
  "name": "@agents-uni/chat",
  "version": "0.5.0",
  "description": "Group chat service for agent universes — a conversational wrapper over OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agents-chat": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts serve",
    "start": "tsx src/index.ts serve",
    "serve": "tsx src/index.ts serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agents",
    "multi-agent",
    "group-chat",
    "openclaw",
    "ai-agents",
    "agent-chat"
  ],
  "author": "agents-uni",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agents-uni/chat.git"
  },
  "homepage": "https://agents-uni.github.io",
  "bugs": {
    "url": "https://github.com/agents-uni/chat/issues"
  },
  "dependencies": {
    "@agents-uni/core": "^0.3.0",
    "@agents-uni/rel": "^0.2.0",
    "@hono/node-server": "^1.13.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
